{
  "$schema": "https://mimo.xiaomi.com//config.json",
  "model": "mimo/mimo-v2.5-pro",
  "small_model": "mimo/mimo-v2.5-pro",
  "default_agent": "build",
  "share": "manual",
  "autoupdate": "notify",
  "instructions": [
    "../AGENTS.md",
    "../CLAUDE.md"
  ],
  "permission": {
    "*": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 2
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".staging/**",
      ".serena/**"
    ]
  },
  "agent": {
    "researcher": {
      "description": "Read-only research agent for fan-out reads, greps, and knowledge lookups. Never edits files.",
      "model": "mimo/mimo-v2.5-pro",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  },
  "command": {
    "test": {
      "template": "Run the full test suite with coverage report using pnpm. Run tests in parallel. Report pass/fail counts and coverage per package.",
      "description": "Run tests with coverage"
    },
    "lint": {
      "template": "Lint and auto-format all changed files. Fix auto-fixable issues. List manual-fix issues with file:line and rule name.",
      "description": "Lint and format changed files"
    },
    "build": {
      "template": "Build the project with pnpm build. Show TypeScript errors, bundle sizes, and warnings. Stop on first error.",
      "description": "Build the project"
    },
    "sync-mcp": {
      "template": "Run: node scripts/sync-mcp-configs.mjs — syncs .mcp.json to all 5 agent configs.",
      "description": "Sync MCP configs to all agents"
    }
  },
  "skills": {
    "paths": [
      "~/.config/mimocode/skills/"
    ]
  },
  "mcp": {
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true
    },
    "searxng": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-searxng"
      ],
      "enabled": true,
      "environment": {
        "SEARXNG_URL": "https://baresearch.org"
      }
    },
    "open-websearch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "open-websearch"
      ],
      "enabled": true,
      "environment": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo"
      }
    },
    "mcp-crawl": {
      "type": "local",
      "command": [
        "node",
        "./scripts/crawl-mcp/server.js"
      ],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "."
      ],
      "enabled": true
    },
    "codebase-memory": {
      "type": "local",
      "command": [
        "C:/Users/C5420321/AppData/Local/Programs/codebase-memory-mcp/codebase-memory-mcp.exe"
      ],
      "enabled": true
    },
    "chirag127": {
      "type": "remote",
      "url": "https://mcp.smithery.run/chirag127",
      "enabled": true
    },
    "one-search-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "one-search-mcp"
      ],
      "enabled": true,
      "environment": {
        "SEARCH_PROVIDER": "local"
      }
    },
    "resend": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "resend-mcp"
      ],
      "enabled": true,
      "environment": {
        "RESEND_API_KEY": "${RESEND_API_KEY}",
        "SENDER_EMAIL_ADDRESS": "chirag@oriz.in"
      }
    },
    "screenpipe": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "screenpipe@latest",
        "mcp"
      ],
      "enabled": true,
      "environment": {
        "SCREENPIPE_API_KEY": "sp-c1aa9d65"
      }
    }
  }
}
