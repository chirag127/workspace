# Master oriz hub. Submodules carry their own .gitignore.
.env
.env.local
.env.*.local
.env.bak
.env.bak.*
.env.example.lock
.sops-age-key.txt
*.log
.vscode/*
.idea/
.DS_Store
node_modules/
dist/
.astro/
.wrangler/
.firebase/
firebase-debug.log
repos/oriz/own/lib/npm/astro-test-utils-npm-pkg
pnpm-lock.yaml
.tmp-*
logs

# Obsidian — local notebook surface, not for repo
.obsidian/
*.base
*.canvas

# Vault wiring exception: knowledge/.obsidian/ committed (Q11/Q12 lock)
# — declared plugins + app.json travel with the repo; workspace state stays local.
!.obsidian/
!.obsidian/app.json
!.obsidian/community-plugins.json

# Obsidian workspace state (per-machine, don't commit)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json
.obsidian/cache/

# Scratch markdown — daily notes / scratch files outside knowledge/
/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9].md
/a.md
/p.md
/Untitled*.md

# Local scratch scripts — one-offs, never CI
/cf_cleanup.py
/scripts/fix-gh-pages-certs*.mjs
/scripts/fix-gh-pages-certs*.json
/scripts/rollout-api-docs.sh

# Playwright CLI sandbox (created by smoke runs, not source)
.playwright-cli/

# Allow workspace MCP config for Cline even though .vscode/ is ignored
!.vscode/mcp.json

# Knowledge graph index — local-only, regenerated via mcp__codebase-memory__index_repository
.codebase-memory/

# Skills — content now lives directly in .claude/skills/ (real files, not junctions)
# Track skills that belong to the workspace; ignore agent-local only
.agents/skills
.kilocode/skills
.opencode/skills
.gemini/skills
# .claude/skills IS tracked — it's the canonical source now (no longer a junction)

.gemini/

# Local scratch / staging — not source
.staging/

# Per-machine agent state — auth tokens, per-host settings
.claude/settings.local.json

# Fleet-cut agent leftovers 2026-07-01 — do not commit
.codeep/
.gocode/
.zhanlu/
.qodo/

# Root scratch scratchpads (delete these files if they exist)
/foo.txt
/test.md

# Scratch tmp dir — local-only ephemeral outputs, never commit
/tmp/
