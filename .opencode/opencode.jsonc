// OpenCode workspace config. See https://opencode.ai/docs/config
// Reads AGENTS.md from workspace root automatically.
{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "../AGENTS.md",
    "../CLAUDE.md"
  ],
  "mcp": {
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ]
    },
    "searxng": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-searxng"
      ],
      "environment": {
        "SEARXNG_URL": "https://baresearch.org"
      }
    },
    "open-websearch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "open-websearch"
      ]
    },
    "mcp-crawl": {
      "type": "local",
      "command": [
        "node",
        "./scripts/crawl-mcp/server.js"
      ]
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "."
      ]
    },
    "codebase-memory": {
      "type": "local",
      "command": [
        "C:/Users/C5420321/AppData/Local/Programs/codebase-memory-mcp/codebase-memory-mcp.exe"
      ]
    }
  }
}