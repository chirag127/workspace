{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "../AGENTS.md",
    "../CLAUDE.md"
  ],
  "mcp": {
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true
    },
    "searxng": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-searxng"
      ],
      "enabled": true,
      "environment": {
        "SEARXNG_URL": "https://baresearch.org"
      }
    },
    "open-websearch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "open-websearch"
      ],
      "enabled": true,
      "environment": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo"
      }
    },
    "mcp-crawl": {
      "type": "local",
      "command": [
        "node",
        "./scripts/crawl-mcp/server.js"
      ],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "."
      ],
      "enabled": true
    },
    "codebase-memory": {
      "type": "local",
      "command": [
        "C:/Users/C5420321/AppData/Local/Programs/codebase-memory-mcp/codebase-memory-mcp.exe"
      ],
      "enabled": true
    },
    "chirag127": {
      "type": "remote",
      "url": "https://mcp.smithery.run/chirag127",
      "enabled": true
    },
    "one-search-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "one-search-mcp"
      ],
      "enabled": true,
      "environment": {
        "SEARCH_PROVIDER": "local"
      }
    }
  }
}
