{
  "$schema": "https://raw.githubusercontent.com/Kilo-Org/kilocode/main/schemas/mcp-settings.json",
  "mcpServers": {
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {}
    },
    "searxng": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-searxng"
      ],
      "env": {
        "SEARXNG_URL": "https://baresearch.org"
      }
    },
    "open-websearch": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "open-websearch"
      ],
      "env": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo"
      }
    },
    "mcp-crawl": {
      "type": "stdio",
      "command": "node",
      "args": [
        "./scripts/crawl-mcp/server.js"
      ]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "."
      ]
    },
    "codebase-memory": {
      "command": "C:/Users/C5420321/AppData/Local/Programs/codebase-memory-mcp/codebase-memory-mcp.exe",
      "args": []
    },
    "chirag127": {
      "type": "http",
      "url": "https://mcp.smithery.run/chirag127"
    },
    "one-search-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "one-search-mcp"
      ],
      "env": {
        "SEARCH_PROVIDER": "local"
      }
    }
  }
}
