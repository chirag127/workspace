{
  "name": "oriz-master",
  "private": true,
  "version": "0.0.0",
  "description": "Master pointer for the chirag127/oriz family. Top-level pnpm scripts only; per-app builds live in their submodules.",
  "scripts": {
    "env:encrypt": "sops --encrypt --input-type dotenv --output-type dotenv .env > .env.enc",
    "env:decrypt": "sops --decrypt --input-type dotenv --output-type dotenv .env.enc > .env",
    "env:edit": "sops .env.enc"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "workspaces": [
    "repos/oriz/own/lib/npm/*",
    "repos/oriz/own/prod/apps/hub/*",
    "repos/oriz/own/prod/apps/personal/*",
    "repos/oriz/own/prod/apps/content/*",
    "repos/oriz/own/prod/apps/tools/*",
    "repos/oriz/own/svc/api/*",
    "repos/oriz/own/content/books/*",
    "repos/oriz/own/prod/bs-ext/*",
    "repos/oriz/own/prod/ide-ext/*",
    "repos/oriz/own/svc/mcp/*",
    "repos/oriz/own/content/skills/*",
    "!repos/oriz/own/content/data/*"
  ]
}
