# ============================================================================
# MIRROR HOSTS — 7-host weekly cron from .github/workflows/mirror-all.yml
# Each block: ENABLE flag, then credentials, then where-to-get them.
# Flip ENABLE_MIRROR_<HOST>=1 to activate. Default 0 = skip (host broken /
# signup unavailable / requires AWS card). Variables kept on disk so they
# light up the moment a host comes back.
#
# Where these go: workflow lives at oriz-org/workspace, so secrets +
# ENABLE_MIRROR_* variables push to the **oriz-org** org level:
#   gh secret   set MIRROR_GITLAB_TOKEN          --org oriz-org --visibility all --body "$VALUE"
#   gh variable set ENABLE_MIRROR_CODEBERG       --org oriz-org --visibility all --body 1
# Full loop: knowledge/runbooks/hosting/mirror-all-hosts-setup.md
# ============================================================================

# --- 1. GitLab.com (working 2026-06-28) ---
# Sign up: https://gitlab.com
# Token:   https://gitlab.com/-/user_settings/personal_access_tokens
#          → Add new token → name "oriz-mirror-bot" → scopes: api + write_repository → expiry 1 year
ENABLE_MIRROR_GITLAB=1
MIRROR_GITLAB_TOKEN=
MIRROR_GITLAB_USERNAME=

# --- 2. Codeberg.org (DOWN 2026-06-28 — re-enable when status page is green) ---
# Status:  https://status.codeberg.eu (and Mastodon @codeberg)
# Sign up: https://codeberg.org/user/sign_up
# Token:   https://codeberg.org/user/settings/applications
#          → Manage Access Tokens → Generate Token → name "oriz-mirror-bot" → scope: write:repository
ENABLE_MIRROR_CODEBERG=0
MIRROR_CODEBERG_TOKEN=
MIRROR_CODEBERG_USERNAME=

# --- 3. Bitbucket Cloud (DISABLED 2026-06-28 — access-tokens page 404'd, re-check) ---
# Sign up: https://bitbucket.org/account/signup
# Token:   https://bitbucket.org/account/settings/access-tokens/
#          (If 404: Workspace → Settings → Security → Access tokens)
#          → Create access token → name "oriz-mirror-bot" → permissions: Repositories Write + Projects Read
#          NOTE: Use Workspace Access Token (NOT App Password — those were retired 2026-07-28)
ENABLE_MIRROR_BITBUCKET=0
MIRROR_BITBUCKET_API_TOKEN=
MIRROR_BITBUCKET_USERNAME=

# --- 4. GitFlic.ru (DISABLED 2026-06-28 — signup form broken at https://gitflic.ru/auth/signup/first-step) ---
# Sign up: https://gitflic.ru/auth/signup/first-step  (retry when fixed)
# Token:   https://gitflic.ru/user/settings/tokens
#          → Create token → name "oriz-mirror-bot" → scope: repo:write
ENABLE_MIRROR_GITFLIC=0
MIRROR_GITFLIC_TOKEN=
MIRROR_GITFLIC_USERNAME=

# --- 5. Azure DevOps (working 2026-06-28) ---
# Sign up: https://dev.azure.com  (free, 5 users, unlimited repos)
# Setup:   Create org (e.g. "chirag127") → create project (e.g. "mirrors")
# Token:   https://dev.azure.com/{org}/_usersSettings/tokens
#          → + New Token → name "oriz-mirror-bot" → org: select specific org (NOT "all") → expiry 1 year
#          → custom scope: Code → Manage
ENABLE_MIRROR_AZURE_DEVOPS=1
MIRROR_AZURE_DEVOPS_TOKEN=
MIRROR_AZURE_DEVOPS_ORG=
MIRROR_AZURE_DEVOPS_PROJECT=

# --- 6. NotABug.org (Gogs — intermittently flaky, workflow has continue-on-error) ---
# Sign up: https://notabug.org/user/sign_up
# Token:   https://notabug.org/user/settings/applications
#          → Manage Access Tokens → Generate New Token → name "oriz-mirror-bot"
#          → COPY IMMEDIATELY: Gogs shows the token once, no second chance
ENABLE_MIRROR_NOTABUG=1
MIRROR_NOTABUG_TOKEN=
MIRROR_NOTABUG_USERNAME=

# --- 7. Radicle (P2P — no signup, no card, free public seed `radicle.garden`) ---
# Local one-time bootstrap:
#   curl -sSf https://radicle.xyz/install | sh
#   rad auth                                # pick alias + strong passphrase
#   tar czf - -C ~/.radicle keys | base64 -w0    # paste output into MIRROR_RADICLE_KEYPAIR_TAR_B64
ENABLE_MIRROR_RADICLE=1
MIRROR_RADICLE_KEYPAIR_TAR_B64=
MIRROR_RADICLE_PASSPHRASE=

# --- 8. AWS CodeCommit (DISABLED — AWS halted new-account onboarding mid-2024) ---
# Kept here for the future in case AWS re-opens onboarding. To re-enable:
# 1. Log in to https://console.aws.amazon.com/iam/
# 2. IAM → Users → select your user → Security credentials tab
# 3. Generate credentials under "HTTPS Git credentials for AWS CodeCommit"
#    → copy to MIRROR_CODECOMMIT_USERNAME + MIRROR_CODECOMMIT_PASSWORD
# 4. Set MIRROR_CODECOMMIT_REGION (e.g. us-east-1)
# 5. Security credentials → Access keys → Create access key (CLI usage)
#    → copy to MIRROR_AWS_ACCESS_KEY_ID + MIRROR_AWS_SECRET_ACCESS_KEY (for `aws codecommit create-repository`)
# Note: workflow's matrix does NOT include CodeCommit until you also wire it back into
# .github/workflows/mirror-all.yml. ENABLE flag alone won't make it run.
ENABLE_MIRROR_CODECOMMIT=0
MIRROR_CODECOMMIT_USERNAME=
MIRROR_CODECOMMIT_PASSWORD=
MIRROR_CODECOMMIT_REGION=
MIRROR_AWS_ACCESS_KEY_ID=
MIRROR_AWS_SECRET_ACCESS_KEY=
# ============================================================================

MISTRAL_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_WORKSPACE=
NEKOWEB_API_KEY=
NEOCITIES_API_KEY=
NPM_TOKEN=
NTFY_SERVER=
NTFY_TOPIC=
NVIDIA_API_KEY=
OLLAMA_CLOUD_API_KEY=
OMDB_API_KEY=
OMNIROUTE_API_KEY=
OPENAQ_KEY=
OPENCODE_ZEN_API_KEY=
OPENROUTER_API_KEY=

# ============================================================================
# ORIZ FLEET — analytics + observability (5 services, all free, no card)
# Used by api-fleet-template Astro Integration on every API site.
# Each repo's GitHub Actions reads these from oriz-org org-level secrets at
# build time and inlines <script> tags into the rendered HTML.
# Mirror these into org secrets via:
#   gh secret set <NAME> --org oriz-org --visibility all --body "<value>"
# ============================================================================

# --- 1. Google Analytics 4 (Measurement ID, format: G-XXXXXXXXXX) ---
# Sign up: https://analytics.google.com  (existing Google account)
# Setup:   Admin (gear icon) → Account column → Create → Account
#            name "oriz-org" → accept defaults
#          → Property column → Create → Property
#            name "oriz fleet APIs" → time zone "India Standard Time" → INR
#          → Business details: Technology, Small → Next
#          → Business objectives: any (e.g. "Get baseline reports") → Create
#          → Platform: Web → URL https://api.oriz.in
#            → Stream name "oriz fleet" → Create stream
# Token:   "Measurement ID" at top of Web stream details page (G-XXXXXXXXXX)
ORIZ_FLEET_GOOGLE_ANALYTICS_MEASUREMENT_ID=

# --- 2. Microsoft Clarity (10-char project ID) ---
# Sign up: https://clarity.microsoft.com  (Microsoft/GitHub/Google OAuth)
# Setup:   Add new project → name "oriz fleet" → URL https://api.oriz.in
#          → Category: Technology / Internet → Create
# Token:   Setup tab → install snippet → last arg of c(...) call is the ID
#          e.g. (function(c,l,a,r,i,t,y){...})(...,"XXXXXXXXXX")
ORIZ_FLEET_MICROSOFT_CLARITY_PROJECT_ID=

# --- 3. PostHog (project key + host URL) ---
# Sign up: https://posthog.com → Get started — free  (email or GitHub OAuth)
# Pick region: US (us.i.posthog.com) gives bigger free tier (1M events/mo);
#              EU (eu.i.posthog.com) is privacy-friendlier
# Token:   Settings → Project → Project API Key  (phc_...)
# Host:    https://us.i.posthog.com  OR  https://eu.i.posthog.com
ORIZ_FLEET_POSTHOG_PROJECT_API_KEY=
ORIZ_FLEET_POSTHOG_API_HOST=

# --- 4. Sentry (browser DSN) ---
# Sign up: https://sentry.io → Sign up  (email or GitHub OAuth)
# Setup:   Select a platform → Browser JavaScript (NOT a framework) → Continue
# Token:   Project Settings → Client Keys (DSN) → copy DSN field
#          Format: https://abc123@o123456.ingest.us.sentry.io/1234567
ORIZ_FLEET_SENTRY_DSN_BROWSER_SDK=

# --- 5. Cloudflare Web Analytics (beacon token, privacy-first, cookieless) ---
# Sign up: https://dash.cloudflare.com  (existing CF account — same one as oriz.in DNS)
# Setup:   Analytics & Logs → Web Analytics → Add a site
#          → Site URL: api.oriz.in → Automatic Setup OFF (need manual snippet)
#          → Done
# Token:   Snippet shows <script ... data-cf-beacon='{"token": "XXX..."}'>
#          Copy ONLY the token string (not the wrapping JSON)
ORIZ_FLEET_CLOUDFLARE_WEB_ANALYTICS_TOKEN=
# ============================================================================

